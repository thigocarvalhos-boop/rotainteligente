generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  GESTOR
  TECNICO
  AUDITOR
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(TECNICO)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectsResponsible Project[]        @relation("ProjectResponsible")
  projectHistories    ProjectHistory[]
  documentChecks      DocumentCheck[]
  auditLogs           AuditLog[]
}

model Edital {
  id          String   @id @default(cuid())
  nome        String
  financiador String
  area        String?
  valorMin    Float?
  valorMax    Float    @default(0)
  prazo       DateTime?
  status      String   @default("Aberto")
  aderencia   Int      @default(3)
  categoria   String   @default("Outro")
  linha       String?
  porte       String   @default("Médio")
  descricao   String?
  link        String?
  observacao  String?
  criteriosJson          Json?
  documentosObrigatorios Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects    Project[]
}

model Project {
  id              String   @id @default(cuid())
  nome            String
  financiador     String
  area            String
  valor           Float
  status          String   @default("Triagem")
  probabilidade   Int      @default(50)
  risco           String   @default("Médio")
  prazo           DateTime?
  observacao      String?
  proximoPasso    String?
  editalId        String?
  publico         String?
  territorio      String?
  competitividade String?
  aderencia       Int?
  edital          String?
  ptScore         Float?
  ptCriterios     Json?
  historico       Json?
  changeLog       Json?
  ano             Int?
  categoriaEdital String?
  programaInterno String?
  vigenciaInicio  DateTime?
  vigenciaFim     DateTime?
  progressoFisico     Float?
  progressoFinanceiro Float?
  scoreCompliance     Float?
  scoreRiscoGlosa     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  responsavelId String?
  responsavel   User?   @relation("ProjectResponsible", fields: [responsavelId], references: [id])

  editalRef        Edital?           @relation(fields: [editalId], references: [id])
  documents        Document[]
  alerts           Alert[]
  complianceChecks ComplianceCheck[]
  histories        ProjectHistory[]
  auditLogs        AuditLog[]
}

model Document {
  id          String    @id @default(cuid())
  projectId   String?
  tipo        String?
  nome        String
  url         String?
  validade    DateTime?
  obrigatorio Boolean   @default(false)
  status      String    @default("Pendente")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checks  DocumentCheck[]
}

model DocumentCheck {
  id         String   @id @default(cuid())
  documentId String
  checkedAt  DateTime @default(now())
  status     String
  observacao String?
  userId     String?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])
}

model Alert {
  id        String   @id @default(cuid())
  projectId String?
  tipo      String
  nivel     String
  titulo    String?
  mensagem  String
  status    String   @default("PENDENTE")
  prazo     DateTime?
  resolucao String?
  lido      Boolean  @default(false)
  lidoEm    DateTime?
  lidoPor   String?
  data      DateTime @default(now())
  resolvido Boolean  @default(false)
  createdAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model ComplianceCheck {
  id        String   @id @default(cuid())
  projectId String
  item      String
  status    String
  descricao String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectHistory {
  id            String   @id @default(cuid())
  projectId     String
  field         String
  oldValue      String?
  newValue      String?
  justificativa String?
  userId        String?
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  acao       String
  entidade   String
  entidadeId String?
  data       DateTime @default(now())
  detalhes   Json?
  antes      Json?
  depois     Json?

  userId    String?
  projectId String?

  user    User?    @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}
